# Copier ce fichier en `.env.local` pour le développement local.
# En production, définir ces variables dans Vercel → Settings → Environment Variables.

# Domaine canonique du site (SEO : sitemap, canonicals, Open Graph).
# Choisir la version définitive (avec ou sans www) et ne plus en changer.
NEXT_PUBLIC_SITE_URL=https://ovedex.com

# --- Envoi des e-mails de formulaire (Resend) ---
# Ces trois variables sont déjà configurées en production sur Vercel.

# Clé API Resend. Obligatoire : sans elle, /api/contact renvoie une erreur 500
# et les formulaires affichent un message d'échec au visiteur.
RESEND_API_KEY=re_xxxxxxxxxxxx

# Adresse qui reçoit les demandes des formulaires.
# Par défaut : l'adresse définie dans lib/contact.ts.
CONTACT_FORM_TO=contact@ovedex.com

# Adresse expéditrice. Son domaine DOIT être vérifié dans le compte Resend :
# c'est ce qui autorise l'envoi vers n'importe quel destinataire.
# Un domaine non vérifié limite l'envoi à l'adresse du propriétaire du compte.
CONTACT_FORM_FROM=Ovedex <no-reply@heyfuture.fr>
